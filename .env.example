# Copy this file to `.env` and fill in your keys. Never commit `.env`.

# OpenRouter — default config (configs/openrouter.yaml). https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Zhipu BigModel direct (configs/bigmodel-direct.yaml). https://bigmodel.cn
BIGMODEL_API_KEY=

# Any OpenAI-compatible proxy/gateway (configs/openai-compatible-proxy.yaml)
PROXY_API_KEY=
